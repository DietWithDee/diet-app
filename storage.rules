rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Secure isAdmin check matching Firestore admin logic
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email in [
          'nanaamadwamena4@gmail.com',
          'princetetteh963@gmail.com',
          'godwinokro2020@gmail.com'
        ]
      );
    }

    match /coverImages/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /articleContentImages/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /eventImages/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

