rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Secure isAdmin check using Firebase Custom Claims or whitelisted emails
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email in ['nanaamadwamena4@gmail.com', 'princetetteh963@gmail.com', 'godwinokro2020@gmail.com']
      );
    }

    match /users/{userId} {
      // User can read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admin can read all profiles (including listing the whole collection)
      allow read, delete: if isAdmin();
      
      match /logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read, delete: if isAdmin();
      }
    }

    match /articles/{articleId} {
      allow read: if isAdmin() || !("status" in resource.data) || resource.data.status == 'published'; // public can only see published
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'helpfulCount', 'notHelpfulCount']);
    }

    match /bookings/{bookingId} {
      allow read, write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // public can read settings (like booking status)
      allow write: if isAdmin(); // only admins can change settings
    }

    match /emails/{emailId} {
      allow create, get: if true; // public can subscribe and check existence
      allow list, update, delete: if isAdmin(); // only admins can list or manage collected emails
    }

    match /articleTags/{tagId} {
      allow read, write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      // Public can only READ approved testimonials, Admin can read all
      allow read: if resource.data.status == 'approved' || isAdmin();
      // Anyone can submit a testimonial (must start as pending, rating 1-5, and not featured)
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.isFeatured == false
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.content != "";
      // Admin only - can update status, toggle featured, delete
      allow update, delete: if isAdmin();
    }

    // Default deny for anything not explicitly specified above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}